# ==============================================================================
# EAOS PLATFORM OPERATIONAL ENVIRONMENT CONFIGURATION (TEMPLATE)
# ==============================================================================

# Môi trường chạy hệ thống (development / production)
EAOS_ENV=development
EAOS_HOST=0.0.0.0
EAOS_PORT=8000

# Cấu hình đường dẫn lưu trữ Docker Data (Tránh cứng hóa đường dẫn vật lý để bảo vệ CI/CD)
DOCKER_DATA_PATH=D:/DockerData/DockerDesktopWSL

# Cấu hình Cơ sở dữ liệu PostgreSQL (Tích hợp Vector Search pgvector)
DATABASE_URL=postgresql://eaos:eaos_pass@localhost:5432/eaos_db
POSTGRES_USER=eaos
POSTGRES_PASSWORD=eaos_pass
POSTGRES_DB=eaos_db
POSTGRES_PORT=5432

# Cấu hình Caching & Hàng đợi thông điệp Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Cấu hình Object Storage (MinIO tương thích S3 cho tệp tin TDO vĩnh cửu)
MINIO_ROOT_USER=eaos_admin
MINIO_ROOT_PASSWORD=eaos_admin_pass
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
AWS_ACCESS_KEY_ID=eaos_s3_key
AWS_SECRET_ACCESS_KEY=eaos_s3_secret
AWS_DEFAULT_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_GOVERNANCE=governance-logs
S3_BUCKET_KNOWLEDGE=knowledge-artifacts

# Cấu hình AI Gateway & LLMs API Keys (Sử dụng qua LiteLLM / Ollama)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
LITELLM_MASTER_KEY=your-litellm-master-key-here
LLM_MODEL_REASONING=deepseek/deepseek-r1
LLM_MODEL_CODING=anthropic/claude-3-5-sonnet
LLM_MODEL_EVALUATION=openai/gpt-4o-mini
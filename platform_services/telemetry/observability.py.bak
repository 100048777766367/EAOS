"""Centralized Observability Service and Automated Middleware Interceptor."""

import time
import uuid
from collections.abc import Awaitable, Callable
from typing import Any

from fastapi import Request, Response
from packages.metrics_engine.domain.models import (
    ArchitectureHealthAggregate,
    MetricType,
    RawMetricObservation,
)
from packages.metrics_engine.domain.ports import MetricsRepositoryPort
from starlette.middleware.base import BaseHTTPMiddleware


class EAOSObservabilityMiddleware(BaseHTTPMiddleware):
    """Automated Interceptor wrapping 100% of HTTP requests to measure Latency & Errors.
    Zero-impact guarantee: any failure in metrics recording must not break responses.
    """

    def __init__(self, app: Any, metrics_repository: MetricsRepositoryPort | None = None, system_id: str = "EAOS-CORE") -> None:
        super().__init__(app)
        self.metrics_repository = metrics_repository
        self.system_id = system_id

    async def dispatch(self, request: Request, call_next: Callable[[Request], Awaitable[Response]]) -> Response:
        start_time = time.perf_counter()
        trace_id = request.headers.get("X-Trace-ID", f"TRC-{uuid.uuid4().hex[:8].upper()}")
        correlation_id = request.headers.get("X-Correlation-ID", f"TX-{uuid.uuid4().hex[:8].upper()}")

        try:
            response = await call_next(request)
        except Exception as exc:
            # record incident metric safely and re-raise without exposing internals
            self._record_metric_safe(metric_type=MetricType.INCIDENT_TREND_RATE, value=1.0, target_component=request.url.path)
            raise exc from None

        duration_ms = (time.perf_counter() - start_time) * 1000.0
        response.headers["X-Trace-ID"] = trace_id
        response.headers["X-Correlation-ID"] = correlation_id

        # record latency and error metrics safely
        self._record_metric_safe(metric_type=MetricType.MTTR_MINUTES, value=duration_ms, target_component=request.url.path)
        if response.status_code >= 400:
            self._record_metric_safe(metric_type=MetricType.RULE_VIOLATION_COUNT, value=1.0, target_component=request.url.path)

        return response

    def _record_metric_safe(self, metric_type: MetricType, value: float, target_component: str) -> None:
        if not self.metrics_repository:
            return
        try:
            aggregate = self.metrics_repository.find_by_system_id(self.system_id)
            if not aggregate:
                aggregate = ArchitectureHealthAggregate(system_id=self.system_id)
            aggregate.add_observation(RawMetricObservation(
                observation_id=f"OBS-{uuid.uuid4().hex[:6].upper()}",
                metric_type=metric_type,
                value=value,
                target_component=target_component,
            ))
            self.metrics_repository.save(aggregate)
        except Exception:
            # suppress any observability failure to preserve response integrity
            pass

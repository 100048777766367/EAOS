FROM python:3.12-slim AS builder

WORKDIR /app
COPY pyproject.toml README.md ./
RUN pip install --no-cache-dir uv && uv venv

COPY apps/ ./apps/
COPY packages/ ./packages/
COPY kernel/ ./kernel/
COPY platform_services/ ./platform_services/

EXPOSE 8000
CMD ["uv", "run", "python", "-m", "uvicorn", "apps.api.app.main:app", "--host", "0.0.0.0", "--port", "8000"]